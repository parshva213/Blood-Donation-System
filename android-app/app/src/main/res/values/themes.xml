<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.BDSystem" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/blood_red</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/blood_red</item>
        <!-- Background color. -->
        <item name="android:windowBackground">@color/bg_color</item>

        <!-- Fix for keyboard covering input fields -->
        <item name="android:windowTranslucentStatus">false</item>
    </style>
</resources>